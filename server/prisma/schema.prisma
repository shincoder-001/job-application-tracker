generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())

  applications Application[]
}

model Application {
  id        Int      @id @default(autoincrement())
  company   String
  position  String
  status    String
  appliedAt DateTime @default(now())
  notes     String?

  userId Int
  user   User @relation(fields: [userId], references: [id])
}